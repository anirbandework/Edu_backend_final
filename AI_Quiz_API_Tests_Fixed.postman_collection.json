				"body": {
					"mode": "raw",
					"raw": "{\n  \"question_text\": \"Explain the water cycle and its stages.\",\n  \"correct_answer\": \"The water cycle consists of evaporation (water turns to vapor), condensation (vapor forms clouds), precipitation (rain/snow falls), and collection (water gathers in bodies of water). This cycle is powered by solar energy.\",\n  \"student_answer\": \"Water goes up and comes down as rain.\",\n  \"max_points\": 12,\n  \"rubric\": \"Full points for mentioning all stages with explanations. Partial credit for incomplete stages.\"\n}"
				},
