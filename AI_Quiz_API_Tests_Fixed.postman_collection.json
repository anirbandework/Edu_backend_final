		{
			"name": "7. Grade Subjective Answer - Good Response",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"question_text\": \"Explain Newton's First Law of Motion with an example.\",\n  \"correct_answer\": \"Newton's First Law states that an object at rest stays at rest and an object in motion stays in motion with the same speed and in the same direction unless acted upon by an unbalanced force. Example: A ball rolling on a smooth surface will continue rolling until friction or another force stops it.\",\n  \"student_answer\": \"Objects don't change their motion unless a force acts on them. Like a book on a table stays there until you push it, and a moving car keeps going until brakes are applied.\",\n  \"max_points\": 10,\n  \"rubric\": \"Full points for correct law statement and relevant example. Partial credit for incomplete understanding.\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/assessment/ai-quiz/grade-subjective",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"assessment",
						"ai-quiz",
						"grade-subjective"
					]
				}
			}
		},
