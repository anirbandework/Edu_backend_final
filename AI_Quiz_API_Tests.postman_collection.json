				"body": {
					"mode": "raw",
					"raw": "{\n  \"question_text\": \"Explain the process of photosynthesis and its importance in the ecosystem.\",\n  \"correct_answer\": \"Photosynthesis is the process by which plants convert light energy into chemical energy (glucose) using carbon dioxide and water. It produces oxygen as a byproduct and is crucial for life on Earth as it provides food and oxygen for other organisms.\",\n  \"student_answer\": \"Photosynthesis is when plants use sunlight, carbon dioxide from air, and water from roots to make glucose (sugar) for energy. This process also releases oxygen into the atmosphere. It's very important because it provides food for plants and oxygen for animals to breathe. Without photosynthesis, there would be no life on Earth.\",\n  \"max_points\": 10,\n  \"rubric\": \"Full points for explaining the process (inputs/outputs), mentioning glucose production, oxygen release, and ecological importance. Partial credit for incomplete explanations.\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/assessment/ai-quiz/grade-subjective",
					"host": [
						"{{base_url}}"
					],
