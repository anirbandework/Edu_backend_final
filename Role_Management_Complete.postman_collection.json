					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/role-management/tenants/{{tenant_id}}/users/{{authority_user_id}}/roles",
							"host": ["{{base_url}}"],
							"path": ["api", "role-management", "tenants", "{{tenant_id}}", "users", "{{authority_user_id}}", "roles"]
						}
					}
				},
