		{
			"name": "Role Management",
			"item": [
				{
					"name": "Create Custom Role",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"role_name\": \"Department Head\",\n  \"subrole\": \"Mathematics Department\",\n  \"description\": \"Head of Mathematics Department\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/role-management/tenants/{{tenant_id}}/roles",
							"host": ["{{base_url}}"],
							"path": ["api", "role-management", "tenants", "{{tenant_id}}", "roles"]
						}
					}
				},
				{
					"name": "Create Role Without Subrole",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"role_name\": \"Coordinator\",\n  \"description\": \"General coordinator role\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/role-management/tenants/{{tenant_id}}/roles",
							"host": ["{{base_url}}"],
							"path": ["api", "role-management", "tenants", "{{tenant_id}}", "roles"]
						}
					}
				},
				{
					"name": "Get All Tenant Roles",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/role-management/tenants/{{tenant_id}}/roles",
							"host": ["{{base_url}}"],
							"path": ["api", "role-management", "tenants", "{{tenant_id}}", "roles"]
						}
					}
				},
