					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/role-management/tenants/{{tenant_id}}/user-roles",
							"host": ["{{base_url}}"],
							"path": ["api", "role-management", "tenants", "{{tenant_id}}", "user-roles"]
						}
					}
				},
				{
					"name": "Assign Single Role",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"user_id\": \"{{authority_user_id}}\",\n  \"user_type\": \"school_authority\",\n  \"role_id\": \"{{role_id}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/role-management/tenants/{{tenant_id}}/assign-role",
							"host": ["{{base_url}}"],
							"path": ["api", "role-management", "tenants", "{{tenant_id}}", "assign-role"]
						}
					}
				},
				{
					"name": "Bulk Assign Roles (Multiple Users)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "[\n  {\n    \"user_id\": \"{{authority_user_id}}\",\n    \"user_type\": \"school_authority\",\n    \"role_id\": \"{{role_id}}\"\n  },\n  {\n    \"user_id\": \"{{teacher_user_id}}\",\n    \"user_type\": \"teacher\",\n    \"role_id\": \"{{role_id}}\"\n  },\n  {\n    \"user_id\": \"{{student_user_id}}\",\n    \"user_type\": \"student\",\n    \"role_id\": \"{{role_id}}\"\n  }\n]"
						},
						"url": {
							"raw": "{{base_url}}/api/role-management/tenants/{{tenant_id}}/bulk-assign-role",
							"host": ["{{base_url}}"],
							"path": ["api", "role-management", "tenants", "{{tenant_id}}", "bulk-assign-role"]
						}
					}
				},
