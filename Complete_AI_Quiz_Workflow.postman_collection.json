						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"topic\": \"Newton's Laws of Motion\",\n  \"subject\": \"Physics\",\n  \"grade_level\": 11,\n  \"question_type\": \"multiple_choice\",\n  \"difficulty\": \"medium\",\n  \"count\": 5,\n  \"learning_objectives\": \"Apply Newton's laws to solve physics problems\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/assessment/ai-quiz/generate-questions?tenant_id={{tenant_id}}&auto_save=false",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"assessment",
								"ai-quiz",
								"generate-questions"
							],
							"query": [
