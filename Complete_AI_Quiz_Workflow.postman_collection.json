									"key": "auto_save",
									"value": "false"
								}
							]
						}
					}
				},
				{
					"name": "2. Grade Subjective Answer with AI",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"question_text\": \"Explain Newton's First Law of Motion and provide a real-world example.\",\n  \"correct_answer\": \"Newton's First Law states that an object at rest stays at rest and an object in motion stays in motion with the same speed and in the same direction unless acted upon by an unbalanced force. Example: A book on a table remains stationary until pushed.\",\n  \"student_answer\": \"Objects don't move unless something pushes them. Like a car needs gas to move and brakes to stop.\",\n  \"max_points\": 10,\n  \"rubric\": \"Award full points for correct law statement and relevant example. Partial credit for incomplete understanding.\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/assessment/ai-quiz/grade-subjective",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"assessment",
								"ai-quiz",
								"grade-subjective"
							]
						}
					}
				},
