		{
			"name": "TEACHER WORKFLOW",
			"item": [
				{
					"name": "1. Create AI Quiz from Scratch",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Physics - Newton's Laws Assessment\",\n  \"description\": \"AI-generated comprehensive assessment on Newton's three laws of motion\",\n  \"instructions\": \"Answer all questions carefully. You have 45 minutes to complete this quiz.\",\n  \"class_ids\": [\"{{class_id}}\"],\n  \"subject\": \"Physics\",\n  \"grade_level\": 11,\n  \"question_types\": [\"multiple_choice\", \"short_answer\", \"true_false\"],\n  \"difficulty_distribution\": {\n    \"easy\": 30,\n    \"medium\": 50,\n    \"hard\": 20\n  },\n  \"total_questions\": 15,\n  \"total_points\": 100,\n  \"time_limit\": 45,\n  \"learning_objectives\": \"Students should understand and apply Newton's three laws of motion to real-world scenarios\",\n  \"topics_to_cover\": [\"First Law - Inertia\", \"Second Law - F=ma\", \"Third Law - Action-Reaction\"],\n  \"allow_retakes\": false,\n  \"show_results_immediately\": false\n}"
						},
						"url": {
							"raw": "{{base_url}}/assessment/ai-quiz-management/create-quiz?teacher_id={{teacher_id}}&tenant_id={{tenant_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"assessment",
								"ai-quiz-management",
								"create-quiz"
							],
							"query": [
								{
									"key": "teacher_id",
									"value": "{{teacher_id}}"
								},
								{
									"key": "tenant_id",
									"value": "{{tenant_id}}"
								}
							]
						}
					}
				},
