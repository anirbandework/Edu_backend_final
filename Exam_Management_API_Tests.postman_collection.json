	"item": [
		{
			"name": "1. Create Physical Education Exam",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    const response = pm.response.json();",
							"    pm.collectionVariables.set('exam_id', response.id);",
							"    pm.test('Exam created successfully', () => {",
							"        pm.expect(response.exam_name).to.eql('Physical Fitness Assessment 2024');",
							"        pm.expect(response.exam_type).to.eql('Sports Day');",
							"    });",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"exam_name\": \"Physical Fitness Assessment 2024\",\n  \"exam_code\": \"PE_SPORTS_2024_Q1\",\n  \"exam_type\": \"Sports Day\",\n  \"description\": \"Comprehensive physical fitness evaluation for all grades\",\n  \"academic_year\": \"2023-24\",\n  \"term\": \"Quarter 1\",\n  \"subject\": \"Physical Education\",\n  \"grade_levels\": [9, 10, 11, 12],\n  \"exam_date\": \"2024-02-15T09:00:00\",\n  \"start_time\": \"2024-02-15T09:00:00\",\n  \"end_time\": \"2024-02-15T11:00:00\",\n  \"duration_minutes\": 120,\n  \"exam_config\": {\n    \"venue\": \"School Sports Ground\",\n    \"equipment_required\": [\"Stopwatch\", \"Measuring Tape\", \"Weighing Scale\"],\n    \"weather_dependent\": true,\n    \"backup_date\": \"2024-02-22T09:00:00\",\n    \"instructor_notes\": \"Ensure all safety equipment is available\"\n  },\n  \"marking_scheme\": {\n    \"total_marks\": 100,\n    \"components\": {\n      \"running_1500m\": {\n        \"max_marks\": 25,\n        \"criteria\": {\n          \"excellent\": {\"time_limit\": \"6:00\", \"marks\": 25},\n          \"good\": {\"time_limit\": \"7:00\", \"marks\": 20},\n          \"average\": {\"time_limit\": \"8:00\", \"marks\": 15},\n          \"below_average\": {\"time_limit\": \"9:00\", \"marks\": 10}\n        }\n      },\n      \"push_ups\": {\n        \"max_marks\": 20,\n        \"criteria\": {\n          \"boys\": {\"excellent\": 30, \"good\": 25, \"average\": 20, \"below_average\": 15},\n          \"girls\": {\"excellent\": 20, \"good\": 15, \"average\": 12, \"below_average\": 8}\n        }\n      },\n      \"flexibility\": {\n        \"max_marks\": 15,\n        \"measurement\": \"sit_and_reach_cm\"\n      },\n      \"coordination\": {\n        \"max_marks\": 20,\n        \"tests\": [\"ball_juggling\", \"ladder_drill\"]\n      },\n      \"attendance_participation\": {\n        \"max_marks\": 20,\n        \"based_on\": \"regular_class_participation\"\n      }\n    }\n  },\n  \"grading_criteria\": {\n    \"A+\": {\"min_percentage\": 90},\n    \"A\": {\"min_percentage\": 80},\n    \"B+\": {\"min_percentage\": 70},\n    \"B\": {\"min_percentage\": 60},\n    \"C\": {\"min_percentage\": 50},\n    \"D\": {\"min_percentage\": 40},\n    \"F\": {\"min_percentage\": 0}\n  },\n  \"class_ids\": [\"{{class_id}}\"]\n}"
				},
				"url": {
					"raw": "{{base_url}}/exam-management/exams?tenant_id={{tenant_id}}&created_by={{school_authority_id}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"exam-management",
						"exams"
					],
					"query": [
